{
  "name": "aozora-obsidian",
  "version": "0.1.0",
  "description": "Obsidian plugin rendering pure Aozora Bunko notation, powered by a bundled aozora-wasm parser.",
  "main": "main.js",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "bun run check && node esbuild.config.mjs production && node scripts/check-wasm.mjs",
    "typecheck": "tsc --noEmit",
    "lint": "biome lint .",
    "lint:fix": "biome lint --write .",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "check": "biome check . && tsc --noEmit",
    "check:fix": "biome check --write . && tsc --noEmit",
    "validate-manifest": "node scripts/validate-manifest.mjs",
    "test": "vitest run --coverage"
  },
  "keywords": [
    "obsidian",
    "obsidian-plugin",
    "aozora",
    "japanese",
    "ruby",
    "tategaki",
    "wasm"
  ],
  "author": "aozora-obsidian contributors",
  "license": "(Apache-2.0 OR MIT)",
  "repository": {
    "type": "git",
    "url": "https://github.com/P4suta/aozora-obsidian.git"
  },
  "homepage": "https://github.com/P4suta/aozora-obsidian",
  "bugs": "https://github.com/P4suta/aozora-obsidian/issues",
  "dependencies": {
    "aozora-wasm": "file:./pkg",
    "minimatch": "^10.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.13",
    "@codemirror/state": "^6.0.0",
    "@codemirror/view": "^6.0.0",
    "@types/node": "^25.6.0",
    "@vitest/coverage-istanbul": "latest",
    "esbuild": "^0.28.0",
    "fast-check": "^4.0.0",
    "happy-dom": "^17.0.0",
    "obsidian": "latest",
    "typescript": "^6.0.3",
    "vitest": "latest"
  }
}
